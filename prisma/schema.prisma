generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  firstName     String
  lastName      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AppSettings {
  id              String   @id @default("main")
  flamePoints     Int      @default(0)
  hasSubscription Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model FlameTransaction {
  id          String   @id @default(cuid())
  amount      Int      // positive = earned, negative = spent
  reason      String   // "chapter_complete", "course_complete", "final_quiz", "course_creation"
  courseId    String?
  chapterId   String?
  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  description String   @default("")
  sourceLinks String   @default("[]")
  flameCost   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chapters    Chapter[]
  finalQuiz   CourseQuiz?
  progress    CourseProgress?
  sessions    StudySession[]
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String
  summary   String   @default("")
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz      Quiz?
  progress  ChapterProgress?
}

model Quiz {
  id        String   @id @default(cuid())
  questions String
  chapterId String   @unique
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ChapterProgress {
  id         String   @id @default(cuid())
  chapterId  String   @unique
  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  completed  Boolean  @default(false)
  score      Int      @default(0)
  completedAt DateTime?
  flameAwarded Boolean @default(false)
}

model CourseQuiz {
  id       String @id @default(cuid())
  questions String
  courseId  String @unique
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseProgress {
  id           String   @id @default(cuid())
  courseId     String   @unique
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completed    Boolean  @default(false)
  score        Int      @default(0)
  passedAt     DateTime?
  flameAwarded Boolean  @default(false)
  sessions     StudySession[]
}

model StudySession {
  id             String   @id @default(cuid())
  userId         String?
  chapterId      String?
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseProgress CourseProgress? @relation(fields: [courseId], references: [courseId], onDelete: Cascade)
  startTime      DateTime
  endTime        DateTime?
  durationSeconds Int     @default(0)
}
